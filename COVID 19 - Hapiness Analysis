import os
from pathlib import Path

import numpy as np
import pandas as pd


BASE_DIR = Path(__file__).resolve().parent
OUTPUT_DIR = BASE_DIR / "Output"
OUTPUT_DIR.mkdir(exist_ok=True)

MPL_CONFIG_DIR = BASE_DIR / ".matplotlib"
MPL_CONFIG_DIR.mkdir(exist_ok=True)
os.environ.setdefault("MPLCONFIGDIR", str(MPL_CONFIG_DIR))

import matplotlib

matplotlib.use("Agg")

import matplotlib.pyplot as plt

try:
    import seaborn as sns
except ModuleNotFoundError:
    sns = None


COVID_FILE_CANDIDATES = [
    BASE_DIR / "Datasets" / "covid19_Confirmed_dataset.csv",
    BASE_DIR / "Datasets" / "Covid19_Confirmed_dataset.csv",
]

HAPPINESS_FILE_CANDIDATES = [

    BASE_DIR / "Dataset" / "worldwide_happiness_report.csv",
    BASE_DIR / "Dataset" / "WorldHappinessReport.csv",

]


def find_existing_file(candidates, label):
    for path in candidates:
        if path.exists():
            return path

    candidate_text = "\n".join(str(path) for path in candidates)
    raise FileNotFoundError(
        f"{label} file could not be found. Checked these paths:\n{candidate_text}"
    )


def load_datasets():
    covid_path = find_existing_file(COVID_FILE_CANDIDATES, "COVID-19 confirmed dataset")
    happiness_path = find_existing_file(HAPPINESS_FILE_CANDIDATES, "World happiness dataset")

    covid = pd.read_csv(covid_path)
    happiness = pd.read_csv(happiness_path)

    print(f"COVID file loaded from: {covid_path}")
    print(f"Happiness file loaded from: {happiness_path}")

    return covid, happiness


def prepare_covid_data(covid):
    metadata_columns = {"Province/State", "Country/Region", "Lat", "Long"}
    date_columns = [
        column
        for column in covid.columns
        if column not in metadata_columns
        and not pd.isna(pd.to_datetime(column, format="%m/%d/%y", errors="coerce"))
    ]

    covid_by_country = (
        covid.drop(columns=["Lat", "Long"], errors="ignore")
        .groupby("Country/Region", as_index=True)[date_columns]
        .sum()
        .sort_index()
    )

    daily_increase = covid_by_country.diff(axis=1).fillna(0)
    covid_summary = pd.DataFrame(
        {
            "country": covid_by_country.index,
            "total_confirmed_last_day": covid_by_country.iloc[:, -1].values,
            "max_infection_rate": daily_increase.max(axis=1).values,
            "first_confirmed_date": covid_by_country.gt(0).idxmax(axis=1).where(
                covid_by_country.gt(0).any(axis=1)
            ),
        }
    )

    return covid_by_country, covid_summary


def prepare_happiness_data(happiness):
    happiness_clean = happiness.rename(
        columns={
            "Country or region": "country",
            "Overall rank": "overall_rank",
            "Score": "happiness_score",
            "GDP per capita": "gdp_per_capita",
            "Social support": "social_support",
            "Healthy life expectancy": "healthy_life_expectancy",
            "Freedom to make life choices": "freedom_to_make_life_choices",
            "Generosity": "generosity",
            "Perceptions of corruption": "perceptions_of_corruption",
        }
    )

    required_columns = [
        "country",
        "happiness_score",
        "gdp_per_capita",
        "social_support",
        "healthy_life_expectancy",
        "freedom_to_make_life_choices",
        "generosity",
        "perceptions_of_corruption",
    ]
    missing_columns = [column for column in required_columns if column not in happiness_clean.columns]
    if missing_columns:
        raise ValueError(f"Missing happiness columns: {missing_columns}")

    return happiness_clean


def merge_analysis_data(covid_summary, happiness_clean):
    merged = covid_summary.merge(happiness_clean, on="country", how="inner")
    merged["log_max_infection_rate"] = np.log(merged["max_infection_rate"].clip(lower=0) + 1)
    return merged.sort_values("max_infection_rate", ascending=False)


def build_correlations(merged):
    metrics = [
        "happiness_score",
        "gdp_per_capita",
        "social_support",
        "healthy_life_expectancy",
        "freedom_to_make_life_choices",
        "generosity",
        "perceptions_of_corruption",
    ]

    correlations = (
        merged[["max_infection_rate", "log_max_infection_rate", *metrics]]
        .corr(numeric_only=True)
        .loc[["max_infection_rate", "log_max_infection_rate"], metrics]
        .T
        .sort_values("log_max_infection_rate", ascending=False)
    )
    return correlations


def build_actionable_insights(merged, correlations):
    top_metric = correlations["log_max_infection_rate"].idxmax()
    top_metric_corr = correlations.loc[top_metric, "log_max_infection_rate"]
    top_countries = ", ".join(merged.head(10)["country"].tolist())

    insights = [
        {
            "area": "Country prioritization",
            "insight": "A small group of countries has the highest peak daily confirmed increases.",
            "evidence": f"Top countries include: {top_countries}.",
            "action": "Use max_infection_rate to prioritize countries for deeper curve and policy review.",
        },
        {
            "area": "Development indicators",
            "insight": "Development indicators are positively associated with peak reported infection growth.",
            "evidence": f"Strongest log-scale correlation is {top_metric}: {top_metric_corr:.3f}.",
            "action": "Interpret higher peaks together with testing capacity, mobility, urbanization, and reporting quality.",
        },
        {
            "area": "Metric limitation",
            "insight": "Raw max infection rate is not population adjusted.",
            "evidence": "The measure is maximum daily confirmed increase, not cases per million.",
            "action": "Add population data before making fair cross-country operational comparisons.",
        },
        {
            "area": "Monitoring",
            "insight": "Daily increases are more useful than cumulative totals for short-term monitoring.",
            "evidence": "max_infection_rate is calculated from daily differences in cumulative cases.",
            "action": "Track daily increases and rolling averages to detect acceleration earlier.",
        },
        {
            "area": "Causality caution",
            "insight": "The analysis shows association, not cause and effect.",
            "evidence": "COVID outcomes are joined with country-level happiness/development indicators.",
            "action": "Frame results as hypotheses, not causal claims.",
        },
    ]

    for _, row in merged.head(5).iterrows():
        insights.append(
            {
                "area": "High-priority country",
                "insight": f"{row['country']} has one of the highest peak daily increases.",
                "evidence": (
                    f"max_infection_rate={row['max_infection_rate']:.0f}; "
                    f"total_confirmed_last_day={row['total_confirmed_last_day']:.0f}; "
                    f"happiness_score={row['happiness_score']:.3f}"
                ),
                "action": "Review curve shape, reporting changes, and intervention timing before comparison.",
            }
        )

    return pd.DataFrame(insights)


def plot_regression(merged, column, label):
    plt.figure(figsize=(9, 5))

    if sns is not None:
        sns.regplot(
            data=merged,
            x=column,
            y="log_max_infection_rate",
            scatter_kws={"alpha": 0.7, "s": 48},
            line_kws={"color": "#B23A48", "linewidth": 2},
        )
    else:
        x = merged[column]
        y = merged["log_max_infection_rate"]
        plt.scatter(x, y, alpha=0.7, s=48, color="#4C78A8")
        if x.nunique() > 1:
            slope, intercept = np.polyfit(x, y, 1)
            x_line = np.linspace(x.min(), x.max(), 100)
            plt.plot(x_line, slope * x_line + intercept, color="#B23A48", linewidth=2)

    plt.title(f"{label} vs. log(max infection rate)")
    plt.xlabel(label)
    plt.ylabel("log(max daily confirmed increase + 1)")
    plt.grid(alpha=0.25)
    plt.tight_layout()
    plt.savefig(OUTPUT_DIR / f"{column}_vs_log_max_infection_rate.png", dpi=160)
    plt.close()


def save_outputs(covid_by_country, covid_summary, happiness_clean, merged, correlations, insights):
    excel_path = OUTPUT_DIR / "covid_happiness_analysis.xlsx"
    insights_path = OUTPUT_DIR / "actionable_insights.txt"

    with pd.ExcelWriter(excel_path, engine="openpyxl") as writer:
        covid_by_country.to_excel(writer, sheet_name="covid_by_country")
        covid_summary.to_excel(writer, sheet_name="covid_summary", index=False)
        happiness_clean.to_excel(writer, sheet_name="happiness", index=False)
        merged.to_excel(writer, sheet_name="merged_analysis", index=False)
        correlations.to_excel(writer, sheet_name="correlations")
        insights.to_excel(writer, sheet_name="actionable_insights", index=False)

    with open(insights_path, "w", encoding="utf-8") as file:
        file.write("Actionable Insights\n")
        file.write("===================\n\n")
        for index, row in insights.iterrows():
            file.write(f"{index + 1}. {row['area']}\n")
            file.write(f"Insight: {row['insight']}\n")
            file.write(f"Evidence: {row['evidence']}\n")
            file.write(f"Action: {row['action']}\n\n")

    plot_specs = [
        ("happiness_score", "Happiness score"),
        ("gdp_per_capita", "GDP per capita"),
        ("social_support", "Social support"),
        ("healthy_life_expectancy", "Healthy life expectancy"),
        ("freedom_to_make_life_choices", "Freedom to make life choices"),
    ]
    for column, label in plot_specs:
        plot_regression(merged, column, label)

    plt.figure(figsize=(10, 6))
    top_15 = merged.head(15).sort_values("max_infection_rate")
    if sns is not None:
        sns.barplot(data=top_15, x="max_infection_rate", y="country", color="#4C78A8")
    else:
        plt.barh(top_15["country"], top_15["max_infection_rate"], color="#4C78A8")
    plt.title("Top 15 countries by max daily confirmed increase")
    plt.xlabel("Max daily confirmed increase")
    plt.ylabel("")
    plt.grid(axis="x", alpha=0.25)
    plt.tight_layout()
    plt.savefig(OUTPUT_DIR / "top_15_max_infection_rate.png", dpi=160)
    plt.close()

    return excel_path, insights_path


def print_summary(covid, happiness, merged, correlations, insights, excel_path, insights_path):
    print("COVID dataset shape:", covid.shape)
    print("Happiness dataset shape:", happiness.shape)
    print("Merged country count:", len(merged))
    print()

    print("Top 10 countries by max infection rate:")
    print(
        merged[
            [
                "country",
                "max_infection_rate",
                "total_confirmed_last_day",
                "happiness_score",
                "gdp_per_capita",
                "social_support",
            ]
        ]
        .head(10)
        .to_string(index=False)
    )
    print()

    print("Correlation with COVID max infection metrics:")
    print(correlations.round(3).to_string())
    print()

    print("Actionable insights:")
    for _, row in insights.head(5).iterrows():
        print(f"- {row['area']}: {row['action']}")
    print()

    print(f"Excel output saved to: {excel_path}")
    print(f"Insights output saved to: {insights_path}")
    print(f"Charts saved under: {OUTPUT_DIR}")


def main():
    covid, happiness = load_datasets()
    covid_by_country, covid_summary = prepare_covid_data(covid)
    happiness_clean = prepare_happiness_data(happiness)
    merged = merge_analysis_data(covid_summary, happiness_clean)
    correlations = build_correlations(merged)
    insights = build_actionable_insights(merged, correlations)
    excel_path, insights_path = save_outputs(
        covid_by_country,
        covid_summary,
        happiness_clean,
        merged,
        correlations,
        insights,
    )
    print_summary(covid, happiness, merged, correlations, insights, excel_path, insights_path)


if __name__ == "__main__":
    main()
